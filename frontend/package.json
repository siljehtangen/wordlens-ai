{
  "name": "wordlens-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --mode ssr",
    "build": "qwik build",
    "build.client": "vite build",
    "build.server": "vite build --ssr src/entry.ssr.tsx",
    "preview": "qwik build preview && vite preview --open",
    "lint": "eslint \"src/**/*.ts*\"",
    "fmt": "prettier --write \"src/**/*.ts*\""
  },
  "dependencies": {
    "@builder.io/qwik": "^1.9.0",
    "@builder.io/qwik-city": "^1.9.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "prettier": "^3.0.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.4.0",
    "vite": "^5.0.0"
  }
}
